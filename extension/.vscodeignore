# Keep the published .vsix small: ship only the bundle + manifest + license/readme.
.vscode/**
src/**
test/**
out/**
node_modules/**
**/*.ts
**/*.map
esbuild.js
tsconfig.json
tsconfig.test.json
tsconfig.dev.json
preview/**
# README screenshots are served from GitHub by absolute URL — no need to ship them.
media/screenshots/**
media/icon.svg
.eslintrc.json
**/*.test.ts
**/*.itest.ts
.gitignore
