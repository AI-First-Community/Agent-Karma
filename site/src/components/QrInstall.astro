---
// "Learn & experiment first" block. The QR opens the installable web app (PWA)
// straight into the Learn → Dojo flow, so people can build the habit before
// committing to the VS Code extension.
const base = import.meta.env.BASE_URL;
---

<aside class="qr-install">
  <div class="qr-copy">
    <h2 id="learn-and-experiment">New here? Learn &amp; experiment first</h2>
    <p>
      Before you install the extension, get the idea and <strong>practice in the Validation
      Dojo</strong> — scored by the real engine — right in the <strong>web app</strong>. Install
      it as an app (Add to Home Screen) and it runs offline. Then bring the habit into VS&nbsp;Code.
    </p>
  </div>
  <a class="qr-link" href={`${base}learn/`} aria-label="Open the Agent Karma web app to learn and experiment">
    <img src={`${base}karma-pwa-qr.svg`} width="160" height="160" alt="QR code — scan to open the Agent Karma web app" />
    <span>Scan to open on your phone</span>
  </a>
</aside>

<style>
  .qr-install {
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
    border: 1px solid var(--sl-color-gray-5, #d0d0d0);
    border-radius: 14px;
    padding: 22px 24px;
    margin-top: 1.5rem;
    background: var(--sl-color-gray-7, transparent);
  }
  .qr-copy { flex: 1 1 280px; }
  .qr-copy h2 { margin: 0 0 8px; font-size: 1.15rem; }
  .qr-copy p { margin: 0; font-size: 0.95rem; line-height: 1.55; }
  .qr-copy em { opacity: 0.75; }
  .qr-link {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }
  .qr-link img { display: block; width: 160px; height: 160px; padding: 10px; background: #fff; border-radius: 12px; }
  .qr-link span { font-size: 0.8rem; opacity: 0.8; }
  @media (max-width: 520px) { .qr-link { width: 100%; } }
</style>
