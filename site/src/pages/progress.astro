---
import Base from "../layouts/Base.astro";
import Progress from "../components/Progress.svelte";
---

<Base title="Your progress">
  <p style="margin:0 0 6px"><a href="/dojo/" style="font-size:14px">← Dojo</a></p>
  <h1 style="margin-top:4px">Your progress</h1>
  <p style="color:var(--ak-muted);max-width:560px">
    Earned entirely in the Dojo, scored by the real engine. Your Karma Card below is
    generated by the <strong style="color:var(--ak-text)">same renderer</strong> the
    extension uses.
  </p>
  <Progress client:only="svelte" />
</Base>
